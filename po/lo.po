#: src/main.vala:72 src/topbar.vala:70
msgid "Boxes"
msgstr "ບ໋ອກ"

#: data/org.gnome.Boxes.desktop.in:3
msgid "Virtual machine viewer/manager"
msgstr "ໂຕເບິ່ງ/ຈັດການເຄື່ອງສະເໝືອນ"

#: data/org.gnome.Boxes.desktop.in:4
msgid "View and use virtual machines"
msgstr "ເບິ່ງ ແລະ ໃຊ້ງານເຄື່ອງສະເໝືອນ"

#. Translators: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.Boxes.desktop.in:6
msgid "virtual machine;vm;"
msgstr "ເຄື່ອງສະເໝືອນ;vm;"

#: data/org.gnome.Boxes.metainfo.xml.in:8
msgid "Virtualization made simple"
msgstr "ການຈຳລອງລະບົບແບບງ່າຍດາຍ"

#: data/org.gnome.Boxes.metainfo.xml.in:10
msgid ""
"Select an operating system and let Boxes download and install it for you in "
"a virtual machine."
msgstr "ເລືອກລະບົບປະຕິບັດການ ແລະ ໃຫ້ບ໋ອກດາວໂຫຼດ ແລະ ຕິດຕັ້ງມັນໃຫ້ທ່ານໃນເຄື່ອງສະເໝືອນ."

#: data/org.gnome.Boxes.metainfo.xml.in:15
msgid "Features:"
msgstr "ຄຸນສົມບັດ:"

#: data/org.gnome.Boxes.metainfo.xml.in:17
msgid "Download freely available operating systems"
msgstr "ດາວໂຫຼດລະບົບປະຕິບັດການທີ່ມີໃຫ້ໃຊ້ງານຟຣີ"

#: data/org.gnome.Boxes.metainfo.xml.in:18
msgid ""
"Automatically install CentOS Stream, Debian, Fedora, Microsoft Windows, "
"OpenSUSE, Red Hat Enterprise Linux, and Ubuntu"
msgstr "ຕິດຕັ້ງ CentOS Stream, Debian, Fedora, Microsoft Windows, OpenSUSE, Red Hat Enterprise Linux, ແລະ Ubuntu ແບບອັດຕະໂນມັດ"

#: data/org.gnome.Boxes.metainfo.xml.in:20
msgid ""
"Create virtual machines from operating system images with a couple of clicks"
msgstr "ສ້າງເຄື່ອງສະເໝືອນຈາກໄຟລ໌ຮູບພາບລະບົບປະຕິບັດການດ້ວຍການຄລິກພຽງບໍ່ເທົ່າໃດຄັ້ງ"

#: data/org.gnome.Boxes.metainfo.xml.in:21
msgid ""
"Limit the resources (memory and storage) your virtual machines consume from "
"your system"
msgstr "ຈຳກັດຊັບພະຍາກອນ (ໜ່ວຍຄວາມຈຳ ແລະ ພື້ນທີ່ເກັບຂໍ້ມູນ) ທີ່ເຄື່ອງສະເໝືອນຂອງທ່ານນຳໃຊ້ຈາກລະບົບຂອງທ່ານ"

#: data/org.gnome.Boxes.metainfo.xml.in:22
msgid "Take snapshots of virtual machines to restore to previous states"
msgstr "ຖ່າຍພາບສະຖານະຂອງເຄື່ອງສະເໝືອນເພື່ອຟື້ນຟູຄືນສູ່ສະຖານະກ່ອນໜ້າ"

#: data/org.gnome.Boxes.metainfo.xml.in:23
msgid "Redirect USB devices from your physical machine into virtual machines"
msgstr "ສົ່ງຕໍ່ອຸປະກອນ USB ຈາກເຄື່ອງຄອມພິວເຕີຂອງທ່ານເຂົ້າໄປໃນເຄື່ອງສະເໝືອນ"

#: data/org.gnome.Boxes.metainfo.xml.in:24
msgid "3D acceleration for some of the supported operating systems"
msgstr "ການເລັ່ງກາຣຟິກ 3 ມິຕິສຳລັບບາງລະບົບປະຕິບັດການທີ່ຮອງຮັບ"

#: data/org.gnome.Boxes.metainfo.xml.in:25
msgid "Automatically resize virtual machines displays to the window size"
msgstr "ປັບຂະໜາດຈໍສະແດງຜົນຂອງເຄື່ອງສະເໝືອນໃຫ້ພໍດີກັບຂະໜາດໜ້າຕ່າງໂດຍອັດຕະໂນມັດ"

#: data/org.gnome.Boxes.metainfo.xml.in:26
msgid "Share clipboard between your system and virtual machines"
msgstr "ແບ່ງປັນຄລິບບອດລະຫວ່າງລະບົບຂອງທ່ານ ແລະ ເຄື່ອງສະເໝືອນ"

#: data/org.gnome.Boxes.metainfo.xml.in:27
msgid ""
"Share files to virtual machines by dropping them from your file manager into "
"the Boxes window"
msgstr "ແບ່ງປັນໄຟລ໌ໄປຍັງເຄື່ອງສະເໝືອນໂດຍການລາກໄຟລ໌ຈາກໂຕຈັດການໄຟລ໌ຂອງທ່ານມາໃສ່ໜ້າຕ່າງຂອງບ໋ອກ"

#: data/org.gnome.Boxes.metainfo.xml.in:28
msgid "Setup Shared Folders between your system and virtual machines"
msgstr "ຕັ້ງຄ່າໂຟນເດີທີ່ໃຊ້ຮ່ວມກັນລະຫວ່າງລະບົບຂອງທ່ານ ແລະ ເຄື່ອງສະເໝືອນ"

#. developer_name tag deprecated with Appstream 1.0
#: data/org.gnome.Boxes.metainfo.xml.in:77
msgid "The GNOME Project"
msgstr "ໂຄງການ ກະໂນມ"

#: data/org.gnome.boxes.gschema.xml:11
